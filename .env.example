# 复制为 .env.local 后填写（勿提交 .env.local）
# OpenAI 兼容：代码请求 {LLM_API_BASE}/chat/completions，Bearer 鉴权
#
# OpenAI：base 一般为 https://api.openai.com/v1
# 火山方舟（豆包等）：base 一般为 https://ark.cn-beijing.volces.com/api/v3
#   模型示例：Doubao-Seed-2.0-pro（以控制台开通的推理接入点为准，部分场景为 ep- 开头的接入点 ID）

LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 可选：评分路由专用模型（仅 /api/score 使用；不填则沿用 LLM_MODEL）
# LLM_SCORE_MODEL=
# 可选：本地视频语境解析 /api/video-parse（豆包 Pro 等多模态：`video_url`；不填则沿用 LLM_MODEL）
# LLM_VIDEO_PARSE_MODEL=doubao-seed-2-0-pro-260215
# LLM_VIDEO_PARSE_THINKING=disabled
# 仅当接入点支持 OpenAI 式 response_format=json_object 时设为 true；多数豆包多模态不支持
# LLM_VIDEO_PARSE_JSON_OBJECT=false
# 设为 true 时跳过「HEAD 检测是否为 text/html」仅调试用（默认建议不设）
# LLM_VIDEO_PARSE_SKIP_MIME_PROBE=false
# 本地上传解析（multipart）单文件大小上限（字节），默认约 15MB，上限约 100MB
# LLM_VIDEO_UPLOAD_MAX_BYTES=15728640
# 视频理解较慢时可单独加时（毫秒），不填则沿用 LLM_TIMEOUT_MS
# LLM_VIDEO_PARSE_TIMEOUT_MS=120000

# 可选
# LLM_TEMPERATURE=0.85
# LLM_MAX_TOKENS=512
# LLM_TIMEOUT_MS=60000
# 火山方舟 Seed 等「深度思考」：disabled=直接答、auto=模型自判、enabled=先思考后答（OpenAI 勿配置）
# LLM_THINKING=disabled
# 可选：按任务细分 thinking。**/api/chat 若不设置本项则完全不传 thinking**（不回退 LLM_THINKING，避免方舟等对训练台词 502）
# LLM_CHAT_THINKING=disabled   # 需要显式写时才带上；要与全局一致可同样写 disabled/auto/enabled
# LLM_SCORE_THINKING=auto      # 复杂任务：评分自动深度思考

# 客户端：设为 false 时训练页不请求接口，始终用内置 Mock 台词
# NEXT_PUBLIC_USE_LLM=false
