# 复制为 .env.local 后填写（勿提交 .env.local）
# OpenAI 兼容：代码请求 {LLM_API_BASE}/chat/completions，Bearer 鉴权
#
# OpenAI：base 一般为 https://api.openai.com/v1
# 火山方舟（豆包等）：base 一般为 https://ark.cn-beijing.volces.com/api/v3
#   模型示例：Doubao-Seed-2.0-pro（以控制台开通的推理接入点为准，部分场景为 ep- 开头的接入点 ID）

LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 可选：评分路由专用模型（仅 /api/score 使用；不填则沿用 LLM_MODEL）
# LLM_SCORE_MODEL=

# 可选
# LLM_TEMPERATURE=0.85
# LLM_MAX_TOKENS=512
# LLM_TIMEOUT_MS=60000
# 火山方舟 Seed 等「深度思考」：disabled=直接答、auto=模型自判、enabled=先思考后答（OpenAI 勿配置）
# LLM_THINKING=disabled
# 可选：按任务细分 thinking（未设置则回退到 LLM_THINKING）
# LLM_CHAT_THINKING=disabled   # 简单任务：训练台词更快
# LLM_SCORE_THINKING=auto      # 复杂任务：评分自动深度思考

# 客户端：设为 false 时训练页不请求接口，始终用内置 Mock 台词
# NEXT_PUBLIC_USE_LLM=false
